---
import { folderTree, runtimePipeline } from "../../data/site";
---

<div class="arch">
  <div class="arch-card">
    <p class="eyebrow">Authoring</p>
    <pre class="tree">{folderTree}</pre>
  </div>
  <div class="arch-arrow" aria-hidden="true">→</div>
  <div class="arch-card">
    <p class="eyebrow">Runtime</p>
    <pre class="tree">{runtimePipeline}</pre>
  </div>
</div>

<style>
  .arch {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: stretch;
  }

  .arch-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.1rem 1.15rem;
    box-shadow: var(--shadow-sm);
    min-width: 0;
  }

  .arch-arrow {
    display: grid;
    place-items: center;
    color: var(--syrah);
    font-size: 1.6rem;
    font-weight: 700;
  }

  .tree {
    margin: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--ink);
    white-space: pre;
  }

  @media (max-width: 860px) {
    .arch {
      grid-template-columns: 1fr;
    }

    .arch-arrow {
      transform: rotate(90deg);
      padding: 0.25rem 0;
    }
  }
</style>
